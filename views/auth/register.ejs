<%- include("../partials/header", { title }) %>
<section class="row justify-content-center align-items-center min-vh-100">
  <div class="col-lg-10">
    <div class="row g-0 auth-card shadow-lg overflow-hidden rounded-4">
      <div class="col-lg-5 auth-hero-secondary p-5 d-flex flex-column justify-content-center">
        <span class="badge bg-warning text-dark fw-semibold mb-3">Novo Cadastro</span>
        <h1 class="display-6 fw-bold text-white">Comece a controlar sua vida financeira hoje.</h1>
        <p class="text-white-50 mt-3 mb-0">
          Crie sua conta, receba categorias iniciais e acompanhe receitas e despesas em poucos cliques.
        </p>
      </div>

      <div class="col-lg-7 bg-white p-4 p-lg-5">
        <h2 class="fw-bold mb-2">Criar conta</h2>
        <p class="text-muted mb-4">Preencha os dados abaixo para acessar o sistema.</p>

        <%- include("../partials/messages") %>

        <form action="/register" method="POST" class="row g-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="col-md-6">
            <label for="nome" class="form-label">Nome</label>
            <input
              type="text"
              id="nome"
              name="nome"
              class="form-control"
              value="<%= formData.nome || '' %>"
              required
            />
          </div>

          <div class="col-md-6">
            <label for="email" class="form-label">E-mail</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-control"
              value="<%= formData.email || '' %>"
              required
            />
          </div>

          <div class="col-md-6">
            <label for="senha" class="form-label">Senha</label>
            <input type="password" id="senha" name="senha" class="form-control" required />
          </div>

          <div class="col-md-6">
            <label for="confirmarSenha" class="form-label">Confirmar senha</label>
            <input
              type="password"
              id="confirmarSenha"
              name="confirmarSenha"
              class="form-control"
              required
            />
          </div>

          <div class="col-12 d-grid">
            <button type="submit" class="btn btn-primary btn-lg">Criar conta</button>
          </div>
        </form>

        <p class="text-muted mt-4 mb-0">
          Ja possui conta?
          <a href="/login" class="fw-semibold text-decoration-none">Entrar</a>
        </p>
      </div>
    </div>
  </div>
</section>
<%- include("../partials/footer") %>
