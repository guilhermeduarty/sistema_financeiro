<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Sistema Financeiro</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <% const currentPath = typeof path !== "undefined" ? path : ""; %>
    <% if (currentUser) { %>
      <nav class="navbar navbar-expand-lg navbar-dark app-navbar shadow-sm">
        <div class="container">
          <a class="navbar-brand fw-bold" href="/dashboard">FinanceFlow</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNavbar"
            aria-controls="mainNavbar"
            aria-expanded="false"
            aria-label="Alternar navegacao"
          >
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item">
                <a class="nav-link" href="/dashboard">Dashboard</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/receitas">Receitas</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/despesas">Despesas</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/categorias">Categorias</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/historico">Historico</a>
              </li>
            </ul>

            <div class="d-flex align-items-center gap-3">
              <span class="text-white-50 small">Ola, <%= currentUser.nome %></span>
              <form action="/logout" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
              </form>
            </div>
          </div>
        </div>
      </nav>
    <% } %>

    <main class="<%= currentUser ? 'py-4' : 'auth-wrapper' %>">
      <div class="container">
