<%- include("../partials/header", { title }) %>
<%- include("../partials/messages") %>

<section class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h1 class="h3 fw-bold mb-1"><%= title %></h1>
    <p class="text-muted mb-0">
      Lista de <%= pageType === "receita" ? "entradas" : "saidas" %> cadastradas no sistema.
    </p>
  </div>
  <a href="/transacoes/nova" class="btn btn-primary">Nova transacao</a>
</section>

<section class="card border-0 shadow-sm">
  <div class="card-body">
    <% if (!transactions.length) { %>
      <p class="text-muted mb-0">Nenhuma transacao encontrada.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Descricao</th>
              <th>Categoria</th>
              <th>Data</th>
              <th>Valor</th>
              <th class="text-end">Acoes</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach((transaction) => { %>
              <tr>
                <td><%= transaction.descricao %></td>
                <td><%= transaction.categoria_nome || "Sem categoria" %></td>
                <td><%= new Date(transaction.data).toLocaleDateString("pt-BR") %></td>
                <td class="<%= pageType === 'receita' ? 'text-success' : 'text-danger' %> fw-semibold">
                  R$ <%= Number(transaction.valor).toFixed(2) %>
                </td>
                <td class="text-end">
                  <div class="d-inline-flex gap-2">
                    <a href="/transacoes/<%= transaction.id %>/editar" class="btn btn-sm btn-outline-primary">Editar</a>
                    <form action="/transacoes/<%= transaction.id %>?_method=DELETE" method="POST">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>
<%- include("../partials/footer") %>
