<%- include("../partials/header", { title }) %>
<%- include("../partials/messages") %>

<section class="hero-panel rounded-4 p-4 p-lg-5 mb-4">
  <div class="row align-items-center">
    <div class="col-lg-8">
      <span class="dashboard-kicker">Resumo Financeiro</span>
      <h1 class="display-6 fw-bold mt-2">Mantenha suas financas sob controle todos os dias.</h1>
      <p class="lead text-muted mb-0">
        Seu painel consolida saldo atual, receitas, despesas e o comportamento mensal das transacoes.
      </p>
    </div>
    <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
      <a href="/transacoes/nova" class="btn btn-primary btn-lg">Nova transacao</a>
    </div>
  </div>
</section>

<section class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card stat-card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-2">Saldo atual</p>
        <h2 class="fw-bold <%= summary.saldoAtual >= 0 ? 'text-success' : 'text-danger' %>">
          R$ <%= Number(summary.saldoAtual).toFixed(2) %>
        </h2>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card stat-card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-2">Total de receitas</p>
        <h2 class="fw-bold text-success">R$ <%= Number(summary.totalReceitas).toFixed(2) %></h2>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card stat-card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-2">Total de despesas</p>
        <h2 class="fw-bold text-danger">R$ <%= Number(summary.totalDespesas).toFixed(2) %></h2>
      </div>
    </div>
  </div>
</section>

<section class="row g-4">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h3 class="h5 fw-bold mb-0">Evolucao mensal</h3>
          <span class="badge text-bg-light">Grafico</span>
        </div>
        <canvas id="financialChart" height="150" data-chart='<%- JSON.stringify(chartData) %>'></canvas>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h3 class="h5 fw-bold mb-0">Ultimas transacoes</h3>
          <a href="/historico" class="small text-decoration-none">Ver tudo</a>
        </div>

        <% if (!recentTransactions.length) { %>
          <p class="text-muted mb-0">Nenhuma transacao cadastrada ainda.</p>
        <% } else { %>
          <div class="list-group list-group-flush">
            <% recentTransactions.forEach((transaction) => { %>
              <div class="list-group-item px-0">
                <div class="d-flex justify-content-between">
                  <div>
                    <h4 class="h6 mb-1"><%= transaction.descricao %></h4>
                    <small class="text-muted">
                      <%= transaction.categoria_nome || "Sem categoria" %> -
                      <%= new Date(transaction.data).toLocaleDateString("pt-BR") %>
                    </small>
                  </div>
                  <strong class="<%= transaction.tipo === 'receita' ? 'text-success' : 'text-danger' %>">
                    <%= transaction.tipo === "receita" ? "+" : "-" %> R$ <%= Number(transaction.valor).toFixed(2) %>
                  </strong>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
<%- include("../partials/footer") %>
